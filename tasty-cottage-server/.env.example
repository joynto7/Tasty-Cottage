# Server Configuration
PORT=3000

# MongoDB Configuration
DB_USER=your_mongodb_username
DB_PASS=your_mongodb_password

# JWT Secret (generate a strong random string)
ACCESS_TOKEN_SECRET=your_jwt_secret_here_use_a_long_random_string

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Stripe Payment Gateway
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# bKash Payment Gateway (Sandbox)
BKASH_APP_KEY=your_bkash_app_key_here
BKASH_APP_SECRET=your_bkash_app_secret_here
BKASH_USERNAME=your_bkash_username_here
BKASH_PASSWORD=your_bkash_password_here
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta

# Nagad Payment Gateway (Sandbox)
NAGAD_MERCHANT_ID=your_nagad_merchant_id_here
NAGAD_PUBLIC_KEY=your_nagad_public_key_here
NAGAD_PRIVATE_KEY=your_nagad_private_key_here
NAGAD_BASE_URL=http://sandbox.mynagad.com:10080/remote-payment-gateway-1.0/api/dfs

# Rocket Payment Gateway
ROCKET_MERCHANT_ID=your_rocket_merchant_id_here
ROCKET_API_KEY=your_rocket_api_key_here

# SSLCommerz Configuration (Sandbox)
STORE_ID=your_store_id_here
STORE_PASSWORD=your_store_password_here
IS_LOCALHOST=true
